# .env.example
# Copy this file to .env and fill in your real keys.
#
#   cp .env.example .env          (Mac / Linux / Git Bash)
#   copy .env.example .env        (Windows Command Prompt)
#
# NEVER commit .env — it is listed in .gitignore.
# docker-compose.yml picks this file up automatically when you run:
#   docker compose up --build
#
# For local runs (Streamlit or uvicorn), either:
#   a) Install python-dotenv (`pip install python-dotenv`) — the app auto-loads .env
#   b) Set the vars in your shell before starting:
#        PowerShell : $env:ANTHROPIC_API_KEY = "sk-ant-api03-..."
#        Bash/zsh   : export ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Anthropic (required for real LLM calls) ─────────────────────────────────
# Get yours at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── OpenAI (optional — only needed if you want GPT-4o as the backend) ───────
# Get yours at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-REPLACE_ME

# ── Knowledge root override (optional) ──────────────────────────────────────
# Points the framework at a shared knowledge library.
# Defaults to ./knowledge (the repo subfolder).
# GENAI_KNOWLEDGE_ROOT=/path/to/shared/knowledge
