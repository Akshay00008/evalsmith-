{
  "recipe_id": "insight_extraction",
  "description": "Structured extraction from unstructured docs. Judge scores precision/recall over insight set + evidence_grounding.",
  "composition": {
    "task_modality": "insight_agent",
    "eval_strategy": "judge_llm",
    "latency_budget_ms_p95": 15000,
    "cost_budget_usd_per_1k": 3.0,
    "safety_floor": 0.95,
    "recommendation_shape": "config_bundle"
  },
  "success_criteria": [
    {"metric": "insight_precision", "operator": ">=", "target": 0.85, "operational_floor": 0.70, "is_primary": true, "weight": 1.0},
    {"metric": "insight_recall",    "operator": ">=", "target": 0.80, "operational_floor": 0.65, "is_primary": false, "weight": 1.0},
    {"metric": "schema_validity",   "operator": ">=", "target": 0.98, "operational_floor": 0.90, "is_primary": false, "weight": 0.5}
  ],
  "default_domain": "extraction"
}
