{
  "recipe_id": "chatbot_support",
  "description": "Customer-support chatbot. Judge scores task_success_rate + refusal calibration. Safety floor is tight (over-refusal hurts CSAT).",
  "composition": {
    "task_modality": "chatbot",
    "eval_strategy": "judge_llm",
    "latency_budget_ms_p95": 4000,
    "cost_budget_usd_per_1k": 0.5,
    "safety_floor": 0.97,
    "recommendation_shape": "config_bundle"
  },
  "success_criteria": [
    {"metric": "task_success_rate", "operator": ">=", "target": 0.85, "operational_floor": 0.65, "is_primary": true, "weight": 1.0},
    {"metric": "refusal_calibration", "operator": ">=", "target": 0.95, "operational_floor": 0.85, "is_primary": false, "weight": 1.0},
    {"metric": "p95_latency_ms", "operator": "<=", "target": 3000, "operational_floor": 5000, "is_primary": false, "weight": 0.5}
  ],
  "default_domain": "support_bot"
}
